{
    "compilerOptions": {
        "target": "ES2020",
        "useDefineForClassFields": true,
        "module": "ESNext",
        "lib": [
            "ES2020",
            "DOM",
            "DOM.Iterable"
        ],
        "skipLibCheck": true,
        /* Bundler mode */
        "moduleResolution": "bundler",
        "allowImportingTsExtensions": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "noEmit": true,
        /* Allow JS files for gradual migration */
        "allowJs": true,
        "checkJs": false,
        /* Path aliases */
        "baseUrl": ".",
        "paths": {
            "@/*": ["./*"],
            "@app/*": ["app/*"],
            "@core": ["core/index.ts"],
            "@core/*": ["core/*"],
            "@features/*": ["features/*"],
            "@shared/*": ["shared/*"]
        },
        /* TypeScript strictness - partial strict mode */
        "strict": true,
        "noImplicitAny": false,
        "strictNullChecks": false,
        "noUnusedLocals": false,
        "noUnusedParameters": false,
        "noFallthroughCasesInSwitch": true,
        /* Vite and Node types */
        "types": [
            "vite/client",
            "node"
        ]
    },
    "include": [
        "**/*.ts",
        "vite-env.d.ts"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}
