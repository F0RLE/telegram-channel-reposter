{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Flux Platform",
    "mainBinaryName": "flux-platform",
    "version": "0.0.12",
    "identifier": "com.flux.platform",
    "build": {
        "beforeDevCommand": "npm run dev --prefix src",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "npm run build --prefix src",
        "frontendDist": "../src/dist"
    },
    "app": {
        "withGlobalTauri": true,
        "windows": [
            {
                "title": "Flux Platform",
                "width": 1440,
                "height": 900,
                "resizable": true,
                "fullscreen": false,
                "decorations": false,
                "transparent": false,
                "backgroundColor": "#111015",
                "zoomHotkeysEnabled": true
            }
        ],
        "security": {
            "csp": {
                "default-src": "'self' ipc: http://ipc.localhost",
                "script-src": "'self' 'unsafe-eval' asset: http://asset.localhost",
                "style-src": "'self' 'unsafe-inline' https://fonts.googleapis.com",
                "font-src": "'self' https://fonts.gstatic.com",
                "img-src": "'self' asset: http://asset.localhost blob: data:",
                "connect-src": "'self' ipc: http://ipc.localhost http://localhost:11434 http://127.0.0.1:5000 https://github.com",
                "object-src": "'none'",
                "base-uri": "'self'"
            },
            "capabilities": [
                "default"
            ]
        }
    },
    "bundle": {
        "active": false,
        "targets": [
            "msi",
            "nsis"
        ],
        "resources": [],
        "icon": [
            "icons/icon.ico",
            "icons/icon.png"
        ]
    }
}